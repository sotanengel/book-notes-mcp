{
  "name": "book-notes-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Business book notes management & MCP knowledge server",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "src",
    "mcp-server"
  ],
  "scripts": {
    "validate": "tsx src/cli/index.ts validate",
    "format": "tsx src/cli/index.ts format",
    "index": "tsx src/cli/index.ts index",
    "add": "tsx src/cli/index.ts add",
    "check-refs": "tsx src/cli/index.ts check-refs",
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.10.7",
    "@vitest/coverage-v8": "4.1.5",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "better-sqlite3": "11.7.0",
    "commander": "12.1.0",
    "yaml": "2.8.3",
    "zod": "3.24.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write"
    ],
    "books/**/*.yaml": [
      "tsx src/cli/index.ts validate"
    ]
  }
}
