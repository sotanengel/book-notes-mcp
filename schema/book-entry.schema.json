{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/book-notes-mcp/schema/book-entry.schema.json",
  "title": "BookEntry",
  "description": "A single book note entry",
  "type": "object",
  "required": ["schema_version", "id", "slug", "title", "authors", "status"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*-[a-z]+-[0-9]{4}$",
      "description": "Unique book identifier: {slug}-{last-author-family}-{year}"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*-[a-z]+-[0-9]{4}$",
      "description": "Must match id"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "title_ja": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "isbn_13": {
      "type": "string",
      "pattern": "^[0-9]{13}$"
    },
    "publication_year": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 2100
    },
    "language": {
      "type": "string",
      "enum": ["ja", "en", "zh", "de", "fr", "es", "ko", "other"]
    },
    "genre": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "business", "technology", "psychology", "management",
          "marketing", "economics", "philosophy", "biography", "other"
        ]
      }
    },
    "status": {
      "type": "string",
      "enum": ["to-read", "reading", "completed", "abandoned", "reference"]
    },
    "read_sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start_date"],
        "additionalProperties": false,
        "properties": {
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "pages_read": {
            "type": "integer",
            "minimum": 0
          },
          "notes": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    },
    "rating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "tags": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "summary": {
      "type": "string",
      "maxLength": 2000
    },
    "key_concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "maxLength": 500
          },
          "related_to": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "highlights": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^h-[0-9]{3}$"
          },
          "page": {
            "type": "integer",
            "minimum": 1
          },
          "location": {
            "type": "string",
            "description": "Kindle location number"
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1600
          },
          "note": {
            "type": "string",
            "maxLength": 1000
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            }
          }
        }
      }
    },
    "action_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "action", "priority"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^a-[0-9]{3}$"
          },
          "action": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in-progress", "done", "skipped"],
            "default": "pending"
          },
          "deadline": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["book_id", "relation"],
        "additionalProperties": false,
        "properties": {
          "book_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*-[a-z]+-[0-9]{4}$"
          },
          "relation": {
            "type": "string",
            "enum": ["references", "contradicts", "extends", "applies", "inspired-by"]
          },
          "note": {
            "type": "string",
            "maxLength": 300
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 500
      }
    },
    "ai_generated": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "boolean",
          "default": false
        },
        "key_concepts": {
          "type": "boolean",
          "default": false
        },
        "tags": {
          "type": "boolean",
          "default": false
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "model": {
          "type": "string",
          "maxLength": 100
        }
      }
    }
  }
}
